#include <stdio.h>

// Recursive function to calculate factorial
int fact(int n) {
    if(n == 0 || n == 1)
        return 1;
    else
        return n * fact(n - 1);
}

int main() {
    int n, r;
    int ncr;

    printf("Enter values of n and r (n > r): ");
    scanf("%d %d", &n, &r);

    if(n >= r && r >= 0) {
        ncr = fact(n) / (fact(r) * fact(n - r));
        printf("nCr value = %d\n", ncr);
    } else {
        printf("Invalid input! Ensure that n >= r and r >= 0.\n");
    }

    return 0;
}
